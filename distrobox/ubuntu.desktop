[Desktop Entry]
Name=Ubuntu
GenericName=Terminal entering Ubuntu
Comment=Terminal entering Ubuntu
Categories=Distrobox;System;Utility
Exec=kitty --class ubuntu distrobox enter ubuntu
Icon=/home/anton/.local/share/icons/distrobox/ubuntu.png
Keywords=distrobox;
NoDisplay=true
Terminal=false
Type=Application
Actions=Remove;

[Desktop Action Remove]
Name=Remove Ubuntu from system
Exec=distrobox rm  ubuntu
